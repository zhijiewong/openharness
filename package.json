{
  "name": "@zhijiewang/openharness",
  "version": "2.3.1",
  "description": "Open-source terminal coding agent. Works with any LLM.",
  "type": "module",
  "bin": {
    "openharness": "./dist/main.js",
    "oh": "./dist/main.js"
  },
  "main": "./dist/sdk/index.js",
  "exports": {
    ".": "./dist/sdk/index.js",
    "./cli": "./dist/main.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "!dist/**/test-helpers.*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/main.tsx",
    "build": "tsc",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "test": "node scripts/test.mjs",
    "test:coverage": "node scripts/coverage.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.4.1",
    "commander": "^13.0.0",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.5",
    "react": "^18.3.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "c8": "^11.0.0",
    "husky": "^9.1.7",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "coding-agent",
    "terminal",
    "coding-assistant",
    "ollama",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhijiewong/openharness"
  },
  "bugs": {
    "url": "https://github.com/zhijiewong/openharness/issues"
  },
  "homepage": "https://github.com/zhijiewong/openharness#readme"
}
