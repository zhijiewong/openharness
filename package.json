{
  "name": "@zhijiewang/openharness",
  "version": "0.6.0",
  "description": "Open-source terminal coding agent. Works with any LLM.",
  "type": "module",
  "bin": {
    "openharness": "./dist/main.js",
    "oh": "./dist/main.js"
  },
  "main": "./dist/main.js",
